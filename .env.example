# OpenAI API
OPENAI_API_KEY=sk-...

# Upstash Redis (single cybercity database — same values for local, preview, and production)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Admin dashboard secret (generate with: openssl rand -hex 32)
ADMIN_TOKEN=...

# Comma-separated IPs allowed to access /admin (leave empty to disable restriction)
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# Comma-separated IPs exempt from the 25/day chat rate limit (your own IP for testing)
RATE_LIMIT_BYPASS_IPS=
